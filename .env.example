# ============================================================
# Database (Neon Postgres)
# ============================================================
# Pooled connection — runtime queries (use ?sslmode=require&pgbouncer=true)
DATABASE_URL="postgresql://nestpos:nestpos_dev_password@localhost:5432/nestpos?schema=public"
# Direct connection — Prisma migrations (no pgbouncer)
DIRECT_URL="postgresql://nestpos:nestpos_dev_password@localhost:5432/nestpos?schema=public"

# ============================================================
# NextAuth
# ============================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Required on Render/Vercel/any reverse-proxied host
AUTH_TRUST_HOST="true"

# ============================================================
# Cloudflare R2 (S3-compatible) — optional, only when uploads added
# ============================================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Legacy S3 vars (unused — kept for reference)
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_REGION=""
S3_ENDPOINT=""
NEXT_PUBLIC_S3_URL=""

# ============================================================
# Stripe
# ============================================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ============================================================
# Redis (optional — needed if scaling realtime cartBus beyond 1 instance)
# ============================================================
REDIS_URL="redis://localhost:6379"

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Nest-POS"
